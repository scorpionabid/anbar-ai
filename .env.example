# ─── ANBAR — Environment Variables ───────────────────────────────────────────
# Copy to .env and fill in values before running docker-compose

# General
ENV=development
SECRET_KEY=change-me-to-a-random-secret-key-min-32-chars

# Database
POSTGRES_DB=anbar_dev
POSTGRES_USER=anbar_user
POSTGRES_PASSWORD=anbar_dev_pass_123
DATABASE_URL=postgresql+asyncpg://anbar_user:anbar_dev_pass_123@anbar_postgres:5432/anbar_dev

# Redis
REDIS_URL=redis://anbar_redis:6379/0

# JWT
JWT_SECRET=change-me-to-another-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8090/api/v1
